CREATE TABLE Customers (
    CustomerID NUMBER PRIMARY KEY,
    Name       VARCHAR2(100),
    DOB        DATE,
    Balance    NUMBER(10,2),
    IsVIP      VARCHAR2(5)
);

CREATE TABLE Loans (
    LoanID       NUMBER PRIMARY KEY,
    CustomerID   NUMBER REFERENCES Customers(CustomerID),
    InterestRate NUMBER(5,2),
    DueDate      DATE
);

